#!/usr/bin/env bash
# Setup sudo fallback for environments without sudo
setup_sudo() {
  if ! command -v sudo >/dev/null 2>&1; then
    if [[ "$USER" == "root" ]]; then
      # Create a fake sudo function for root user
      sudo() { "$@"; }
      export -f sudo
    else
      echo "error: sudo not available and not running as root" >&2
      exit 1
    fi
  fi
}

install_packages() {
  local manager=$1
  local cmd=$2
  shift 2

  if [[ $# -eq 0 ]]; then
    return
  fi

  echo "Installing with $manager: $*"
  $cmd "$@"
}

COMMON_XCMD_PACKAGES=(lua starship fastfetch lsd dust gitoxide yadm gh bat sd ripgrep fd bottom
                      procs duf ast-grep git-delta gitui zellij difftastic helix pueue fzf
                      progress atuin fnm hyperfine bitwarden-cli git-lfs just)
MACOS_BREW_PACKAGES=(zsh gnupg python bundler-completion squirrel-app pinentry-mac aviator-co/tap/av)
ARCH_ROOT_PACKAGES=(zsh gnupg python)
ARCH_USER_PACKAGES=(zsh gnupg python unrar)
APT_BASE_PACKAGES=(zsh unzip gpg python3)
UV_TOOL_PACKAGES=(auto-config auto-token httpie)
RUST_TOOLS=(sccache)

ensure_uv() {
  export PATH="$HOME/.local/bin:$PATH"

  if command -v uv >/dev/null 2>&1; then
    echo "uv is already installed"
    return
  fi

  echo "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
}

ensure_xcmd() {
  if command -v x >/dev/null 2>&1; then
    return
  fi

  if [[ -f "$HOME/.x-cmd.root/X" ]]; then
    # bootstrap runs in a non-interactive shell, so source the local entrypoint
    # before falling back to the network installer.
    source "$HOME/.x-cmd.root/X"
  fi

  if command -v x >/dev/null 2>&1; then
    return
  fi

  eval "$(curl -fsSL https://get.x-cmd.com)"
}

ensure_rustup() {
  if command -v cargo >/dev/null 2>&1; then
    return
  fi

  if [[ -f "$HOME/.cargo/env" ]]; then
    source "$HOME/.cargo/env"
  fi

  if command -v cargo >/dev/null 2>&1; then
    return
  fi

  echo "Installing rustup..."
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
  source "$HOME/.cargo/env"
}

install_system_packages() {
  setup_sudo
  if [[ "$OSTYPE" == "darwin"* ]]; then
    if [[ "$USER" == "root" ]]; then
      echo "error: macOS should not run as root user" >&2
      exit 1
    fi

    echo "=== macOS: Installing base packages with brew ==="
    install_packages "brew" "brew install" "${MACOS_BREW_PACKAGES[@]}"
    install_packages "brew cask" "brew install --cask" linearmouse
  elif [[ -f /etc/arch-release ]]; then
    if [[ "$USER" == "root" ]]; then
      echo "=== Arch Linux (root): Installing base packages with pacman ==="
      install_packages "pacman" "pacman -S --noconfirm --needed" "${ARCH_ROOT_PACKAGES[@]}"
    else
      echo "=== Arch Linux: Installing base packages with pacman ==="
      install_packages "pacman" "sudo pacman -S --noconfirm --needed" "${ARCH_USER_PACKAGES[@]}"
    fi
  elif command -v apt >/dev/null 2>&1; then
    echo "=== Ubuntu: Installing base packages with apt ==="
    sudo apt update
    install_packages "apt" "sudo apt install -y" "${APT_BASE_PACKAGES[@]}"
  else
    echo "error: unsupported system" >&2
    exit 1
  fi
}

# Set git gpg.program to current gpg (e.g. Homebrew on macOS)
set_git_gpg_program() {
  if command -v gpg >/dev/null 2>&1; then
    git config --global gpg.program "$(command -v gpg)"
  fi
}

setup_pnpm_home() {
  if [[ -z "${PNPM_HOME:-}" ]]; then
    if [[ "$OSTYPE" == "darwin"* ]]; then
      PNPM_HOME="$HOME/Library/pnpm"
    else
      PNPM_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/pnpm"
    fi
  fi

  export PNPM_HOME
  mkdir -p "$PNPM_HOME"

  case ":$PATH:" in
    *":$PNPM_HOME:"*) ;;
    *) export PATH="$PNPM_HOME:$PATH" ;;
  esac
}

install_node_tooling() {
  if ! command -v fnm >/dev/null 2>&1; then
    echo "fnm is not installed; skipping Node.js and pnpm setup"
    return
  fi

  eval "$(fnm env --shell bash)"

  local current_node_version
  current_node_version=$(fnm current 2>/dev/null || true)
  if [[ -z "$current_node_version" || "$current_node_version" == "system" ]]; then
    echo "Installing Node.js LTS with fnm..."
    fnm install --lts
    fnm use --lts
    current_node_version=$(fnm current 2>/dev/null || true)
  fi

  if [[ -z "$current_node_version" || "$current_node_version" == "system" ]]; then
    echo "warning: fnm did not activate a managed Node.js version; skipping pnpm setup" >&2
    return
  fi

  fnm use "$current_node_version"
  fnm default "$current_node_version"
  setup_pnpm_home

  if ! command -v corepack >/dev/null 2>&1; then
    echo "Installing corepack..."
    npm install --global corepack@latest
    hash -r
  fi

  corepack enable pnpm
  hash -r

  if ! command -v pnpm >/dev/null 2>&1; then
    corepack prepare pnpm@latest --activate
    hash -r
  fi
}

get_nexttrace_platform() {
  local os arch
  case "$(uname -s)" in
    Linux) os="linux" ;;
    Darwin) os="darwin" ;;
    *)
      return 1
      ;;
  esac

  case "$(uname -m)" in
    x86_64|amd64) arch="amd64" ;;
    aarch64|arm64) arch="arm64" ;;
    armv7l|armv7) arch="armv7" ;;
    i386|i686) arch="386" ;;
    riscv64) arch="riscv64" ;;
    loongarch64) arch="loong64" ;;
    s390x) arch="s390x" ;;
    *)
      return 1
      ;;
  esac

  echo "${os}_${arch}"
}

install_nexttrace_if_missing() {
  if command -v nexttrace >/dev/null 2>&1; then
    echo "nexttrace is already installed"
    return
  fi

  local platform
  if ! platform=$(get_nexttrace_platform); then
    echo "warning: skipping nexttrace install on unsupported platform $(uname -s)/$(uname -m)" >&2
    return
  fi

  echo "Installing nexttrace..."
  local tmp_file
  tmp_file=$(mktemp)
  mkdir -p "$HOME/.local/bin"
  curl -fsSL "https://github.com/nxtrace/NTrace-core/releases/latest/download/nexttrace_${platform}" -o "$tmp_file"
  install -m 755 "$tmp_file" "$HOME/.local/bin/nexttrace"
  rm -f "$tmp_file"
}

install_by_uv() {
  for tool in "${UV_TOOL_PACKAGES[@]}"; do
    if [[ "$tool" == "httpie" ]]; then
      install_uv_tool_if_missing "$tool" "http"
      continue
    fi
    install_uv_tool_if_missing "$tool"
  done
  # install nvitop if nvidia-smi exists
  if command -v nvidia-smi >/dev/null 2>&1; then
    install_uv_tool_if_missing "nvitop"
  fi
}

install_by_pnpm() {
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "pnpm is not available; skipping pnpm global installs"
    return
  fi
  setup_pnpm_home
  pnpm install -g opencode-ai
}

install_uv_tool_if_missing() {
  local package=$1
  local binary=${2:-$package}
  if command -v "$binary" >/dev/null 2>&1; then
    echo "$binary is already installed"
    return
  fi

  uv tool install "$package"
}

install_rust_tools() {
  local tool

  ensure_rustup
  if ! command -v cargo-binstall >/dev/null 2>&1; then
    echo "Installing cargo-binstall..."
    cargo install --locked cargo-binstall
  fi

  for tool in "${RUST_TOOLS[@]}"; do
    if command -v "$tool" >/dev/null 2>&1; then
      echo "$tool is already installed"
      continue
    fi

    echo "Installing $tool..."
    if command -v cargo-binstall >/dev/null 2>&1; then
      cargo binstall --no-confirm "$tool"
    else
      cargo install --locked "$tool"
    fi
  done
}

install_misc_tooling() {
  ensure_xcmd
  install_packages "xcmd" "x env use" "${COMMON_XCMD_PACKAGES[@]}"
  ensure_uv
  install_nexttrace_if_missing
  install_by_uv
  install_rust_tools
  install_node_tooling

  if command -v git-lfs >/dev/null 2>&1; then
    git lfs install
  fi
}

config_zsh() {
  if ! command -v zi >/dev/null 2>&1; then
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/z-shell/zi-src/main/lib/sh/install.sh)" -- -i skip
    zsh -cl -- '(source $HOME/.config/zsh/.zi.zsh && @zi-scheduler burst) || true'
  fi
  # setup .zprofile
  if [[ ! -f $HOME/.zprofile ]]; then
    touch $HOME/.zprofile
    echo "emulate sh -c 'source /etc/profile'" | tee -a $HOME/.zprofile
  fi
}

if [[ -n "$GITHUB_ACTIONS" ]]; then
  echo "::group::installing packages"
fi
install_system_packages
install_misc_tooling
install_by_pnpm
set_git_gpg_program
if [[ -n "$GITHUB_ACTIONS" ]]; then
  echo "::endgroup::"
fi

if [[ -n "$GITHUB_ACTIONS" ]]; then
  echo "::group::configuring zsh"
fi
auto-config generate-config
auto-token init
config_zsh
if [[ -n "$GITHUB_ACTIONS" ]]; then
  echo "::endgroup::"
fi
